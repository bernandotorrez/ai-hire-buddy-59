# Supabase client-side values
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_or_anon_key

# Server-side Supabase fallback values for SSR/server functions
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_or_anon_key

# App URL
VITE_APP_URL=http://localhost:5177

# AI provider key for TanStack Start server functions.
# Keep this server-side only. Do not expose it as VITE_*.
SUMOPOD_API_KEY=your_sumopod_api_key

# Vercel/Nitro deployment note:
# Set NITRO_PRESET=vercel in the Vercel dashboard if the TanStack Start wrapper enables Nitro output.
